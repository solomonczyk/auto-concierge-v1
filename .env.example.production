# =============================================================================
# Auto-Concierge — Production .env template
# Copy to .env and fill all CHANGE_ME / YOUR_* values. Never commit .env.
# =============================================================================

# --- Database ---
POSTGRES_SERVER=db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=autoservice

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- Production (required) ---
ENVIRONMENT=production
SECRET_KEY=CHANGE_ME_GENERATE_RANDOM_32_CHARS_MIN
ENCRYPTION_KEY=CHANGE_ME_USE_CRYPTOGRAPHY_FERNET_GENERATE_KEY
TELEGRAM_WEBHOOK_SECRET=CHANGE_ME_RANDOM_SECRET_FOR_WEBHOOK_HEADER

# Generate ENCRYPTION_KEY: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Generate SECRET_KEY: python -c "import secrets; print(secrets.token_urlsafe(32))"

# --- CORS (comma-separated, no wildcard in production) ---
BACKEND_CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com

# --- Telegram ---
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_FROM_BOTFATHER
WEBAPP_URL=https://your-domain.com/concierge
SITE_URL=https://your-domain.com

# --- Optional ---
ENABLE_OUTBOX_WORKER=false
ADMIN_CHAT_ID=
SHOP_TIMEZONE=Europe/Moscow
# GIGACHAT_CLIENT_ID=
# GIGACHAT_CLIENT_SECRET=
# OPENAI_API_KEY=
