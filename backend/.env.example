# --- Database ---
POSTGRES_SERVER=db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_IN_PRODUCTION
POSTGRES_DB=autoservice

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- Production (required when ENVIRONMENT=production) ---
ENVIRONMENT=development
SECRET_KEY=CHANGE_ME_GENERATE_A_SECURE_KEY
TELEGRAM_WEBHOOK_SECRET=
ENCRYPTION_KEY=

# Generate ENCRYPTION_KEY: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# --- Telegram ---
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE
WEBAPP_URL=https://your-domain.com/webapp

# --- Optional ---
# GIGACHAT_CLIENT_ID=
# GIGACHAT_CLIENT_SECRET=
# OPENAI_API_KEY=
